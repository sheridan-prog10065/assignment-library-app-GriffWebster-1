<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LibraryAppInteractive.LibraryAdminPage"
             Title="Manage Book Assets">
    <ContentPage.Content>
        <VerticalStackLayout>
            <Label Text="Library Admin Page"
                   FontSize="Large"/>
            
            <!-- Register Book Section-->
            <VerticalStackLayout
                Spacing="15">
                <Label Text="Register Book"/>

                <Entry x:Name="AdminBookNameEntry"
                       Placeholder="Enter Book Name"/>

                <Entry x:Name="AdminAuthorsEntry"
                           Placeholder="Enter author(s)"/>

                <Entry x:Name="AdminIsbnEntry"
                           Placeholder="Enter ISBN"/>

                <Entry x:Name="AdminAssetCountEntry"
                           Placeholder="Enter number of assets"
                           Keyboard="Numeric" />

                <Button x:Name="RegisterBookButton"
                            Text="Register Book"
                        Clicked="_btnRegisterBookClicked"/>
            </VerticalStackLayout>
            
            
        </VerticalStackLayout>
    </ContentPage.Content>
</ContentPage>